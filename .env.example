# =============================================================================
# Caustier SAV — variables d'environnement
# Copier ce fichier vers .env et renseigner les valeurs.
# =============================================================================

# --- Base de données (PostgreSQL) ---
# URL de connexion Prisma (pooler ou direct)
DATABASE_URL="postgresql://user:password@localhost:5432/caustier_sav"
# Optionnel : URL directe pour les migrations (sans pooler)
# DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/caustier_sav"

# --- Authentification (Better Auth) ---
# OBLIGATOIRE en production — générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-in-production-min-32-chars"
# URL publique de l'application (avec https en production)
BETTER_AUTH_URL="http://localhost:3000"

# --- Email (Resend) ---
# Clé API Resend (https://resend.com/api-keys)
RESEND_API_KEY=""
# Expéditeur (domaine vérifié en prod ; onboarding@resend.dev en dev)
EMAIL_FROM="Caustier SAV <onboarding@resend.dev>"

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_API_KEY=""
PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_VERIFY_TOKEN=""
# OBLIGATOIRE en production pour valider les webhooks Meta
WHATSAPP_APP_SECRET=""
# Si le template Meta `notification_sav` a encore des boutons Accepter/Refuser,
# mettre à 1 pour ne pas renvoyer le message interactif (évite le double CTA).
# Préférable : retirer les boutons du template Meta (corps seul) et laisser 0.
# WHATSAPP_TEMPLATE_HAS_BUTTONS="1"

# --- Assistant IA (optionnel) ---
OLLAMA_MODEL="mistral"

# --- Environnement ---
NODE_ENV="development"

# --- Logs (optionnel) ---
# debug | info | warn | error — défaut : info en prod, debug en dev
LOG_LEVEL="info"
